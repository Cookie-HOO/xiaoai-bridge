# 小米账号。可选：如果使用 userId + passToken 登录，可以留空。
MI_XIAOMI_ACCOUNT=""

# 小米账号密码。可选：如果使用 userId + passToken 登录，可以留空。
MI_XIAOMI_PASSWORD=""

# 小米 userId。推荐填写；可从 account.xiaomi.com 的 cookie / 存储中获取。
MI_XIAOMI_USER_ID=""

# 小米 passToken。推荐填写；通常包含 V1: 前缀，需要完整复制。
MI_XIAOMI_PASS_TOKEN=""

# 要监听的小爱音箱 SN。支持多个，使用英文逗号分隔；推荐通过 uv run xiaoai-select 自动写入。
MI_SPEAKER_SN=""

# 要监听的小爱音箱 MAC。支持多个，使用英文逗号分隔；需要与 MI_SPEAKER_SN 一一对应。
MI_SPEAKER_MAC=""

# 轮询小爱对话记录的间隔，单位：秒。值越小响应越快，但请求也越频繁。
MI_POLL_INTERVAL_SECONDS="1"

# 登录 token 缓存文件路径。用于减少重复登录；删除该文件可强制重新登录。
MI_TOKEN_CACHE_PATH=".data/token_cache.json"

# 本地音频文件对小爱音箱可访问的公网 / 局域网基础 URL。为空时使用本机文件服务地址。
MI_PUBLIC_BASE_URL=""

# 本地音频文件服务监听地址。0.0.0.0 表示监听所有网卡，便于局域网音箱访问。
MI_FILE_SERVER_HOST="0.0.0.0"

# 本地音频文件服务端口。返回本地 mp3 / audio 路径时会用到。
MI_FILE_SERVER_PORT="8765"
